{
  "settings": {
    "analysis": {
      "analyzer": {
        "standard_string": {
          "type": "custom",
          "tokenizer": "icu_tokenizer",
          "filter": [
            "lowercase",
            "icu_folding",
            "decimal_digit",
            "truncate_token_filter"
          ]
        },
        "english_string": {
          "type": "custom",
          "tokenizer": "icu_tokenizer",
          "filter": [
            "english_possessive_stemmer",
            "lowercase",
            "icu_folding",
            "decimal_digit",
            "english_stop",
            "english_stemmer",
            "truncate_token_filter"
          ]
        },
        "slovenian_string": {
          "type": "custom",
          "tokenizer": "icu_tokenizer",
          "filter": [
            "lowercase",
            "icu_folding",
            "decimal_digit",
            "slovenian_lemmatizer",
            "truncate_token_filter"
          ]
        },
        "portuguese_string": {
          "type": "custom",
          "tokenizer": "icu_tokenizer",
          "filter": [
            "lowercase",
            "icu_folding",
            "decimal_digit",
            "portuguese_stop",
            "portuguese_stemmer",
            "truncate_token_filter"
          ]
        }
      },
      "filter": {
        "english_possessive_stemmer": {
          "type": "stemmer",
          "language": "possessive_english"
        },
        "english_stop": {
          "type": "stop",
          "stopwords": "_english_"
        },
        "english_stemmer": {
          "type": "stemmer",
          "language": "english"
        },
        "slovenian_lemmatizer": {
          "type": "lemmagen",
          "lexicon_path": "sl.lem"
        },
        "portuguese_stop": {
          "type": "stop",
          "stopwords": "_portuguese_"
        },
        "portuguese_stemmer": {
          "type": "stemmer",
          "language": "light_portuguese"
        },
        "truncate_token_filter": {
          "type": "truncate",
          "length": 2048
        }
      },
      "normalizer": {
        "display_label_normalizer": {
          "type": "custom",
          "char_filter": [
            "truncate_token_filter"
          ],
          "filter": [
            "lowercase"
          ]
        },
        "id_path_normalizer": {
          "type": "custom",
          "char_filter": [
            "truncate_token_filter"
          ]
        }
      },
      "char_filter": {
        "truncate_token_filter": {
          "type": "pattern_replace",
          "pattern": "^(.{0,2048}).*$",
          "replacement": "$1"
        }
      }
    }
  },
  "mappings": {
    "_source": {
      "enabled": false
    },
    "dynamic": false,
    "properties": {
      "id": {
        "type": "keyword"
      },
      "text": {
        "properties": {
          "en": {
            "type": "text",
            "analyzer": "english_string"
          },
          "sl": {
            "type": "text",
            "analyzer": "slovenian_string"
          },
          "pt": {
            "type": "text",
            "analyzer": "portuguese_string"
          },
          "und": {
            "type": "text",
            "analyzer": "standard_string"
          }
        }
      },
      "claims": {
        "properties": {
          {{range $i, $claimType := $}}
            {{if $i}},{{end}}
            "{{$claimType.Name}}": {
              "type": "nested",
              "properties": {
                {{range $i, $field := $claimType.Fields}}
                  {{if $i}},{{end}}
                  "{{$field.Name}}": {{$field.Definition}}
                {{end}}
              }
            }
          {{end}}
        }
      }
    }
  }
}