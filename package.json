{
  "name": "@peerdb/peerdb",
  "version": "0.4.0-rc.0",
  "type": "module",
  "description": "A collaborative database.",
  "license": "Apache-2.0",
  "author": {
    "name": "PeerDB contributors",
    "url": "https://gitlab.com/peerdb/peerdb"
  },
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/peerdb/peerdb.git"
  },
  "module": "./lib/index.js",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js"
    },
    "./components/*": {
      "types": "./lib/components/*.d.ts",
      "import": "./lib/components/*.js"
    },
    "./partials/*": {
      "types": "./lib/partials/*.d.ts",
      "import": "./lib/partials/*.js"
    },
    "./views/*": {
      "types": "./lib/views/*.d.ts",
      "import": "./lib/views/*.js"
    },
    "./core": {
      "types": "./lib/core/index.d.ts",
      "import": "./lib/core/index.js"
    },
    "./core/*": {
      "types": "./lib/core/*.d.ts",
      "import": "./lib/core/*.js"
    },
    "./document": {
      "types": "./lib/document/index.d.ts",
      "import": "./lib/document/index.js"
    },
    "./document/*": {
      "types": "./lib/document/*.d.ts",
      "import": "./lib/document/*.js"
    },
    "./locales/*": {
      "import": "./lib/locales/*.js"
    },
    "./*.css": {
      "style": "./lib/*.css"
    },
    "./*": {
      "types": "./lib/*.d.ts",
      "import": "./lib/*.js"
    }
  },
  "files": [
    "lib"
  ],
  "scripts": {
    "serve": "vite serve",
    "build": "vite build",
    "build-lib": "vite build --config vite.config.lib.ts && vue-tsc -p tsconfig.lib.json && resolve-tspaths -p tsconfig.lib.json && node generate-vue-dts-proxies.js",
    "lint": "eslint --fix src tests",
    "lint-ci": "eslint --fix --format gitlab src tests",
    "lint-style": "stylelint --fix src/**/*.{css,scss,vue,html}",
    "lint-style-ci": "stylelint --fix --custom-formatter=@studiometa/stylelint-formatter-gitlab src/**/*.{css,scss,vue,html}",
    "lint-vue": "vue-tsc --noEmit && vue-tsc -p tests/tsconfig.json --noEmit",
    "fmt": "prettier src tests *.ts *.js *.json .*.json --write",
    "test": "vitest",
    "coverage": "vitest --coverage",
    "test-ci": "vitest run --reporter junit --reporter default --outputFile tests.xml --coverage",
    "test-e2e": "playwright test --config=playwright.config.ts --update-snapshots=${UPDATE_SCREENSHOTS:-missing} && nyc report",
    "test-e2e-install": "playwright install --with-deps chromium",
    "generate-vue-i18n": "node generate-vue-i18n.js",
    "upgrade": "ncu -u --dep dev,optional,peer,prod,packageManager --peer",
    "check-audit": "check-audit",
    "resolve-audit": "resolve-audit",
    "prepare": "npm run build-lib"
  },
  "peerDependencies": {
    "@all1ndev/vue-local-scope": "^0.3.2",
    "@headlessui/vue": "^1.7.23",
    "@heroicons/vue": "^2.2.0",
    "@sidekickicons/vue": "^0.15.0",
    "@tozd/identifier": "^0.8.1",
    "esm-seedrandom": "^3.0.5-esm.2",
    "lodash-es": "^4.18.1",
    "nouislider": "^15.8.1",
    "structured-field-values": "^2.0.4",
    "tailwind-merge": "^3.5.0",
    "uuid": "^13.0.0",
    "vue": "^3.5.29",
    "vue-i18n": "^11.1.12",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@babel/types": "^7.29.0",
    "@eslint/compat": "^2.0.2",
    "@eslint/js": "^9.39.2",
    "@headlessui/tailwindcss": "^0.2.2",
    "@intlify/devtools-types": "^11.2.8",
    "@intlify/unplugin-vue-i18n": "^11.0.3",
    "@playwright/test": "^1.58.2",
    "@studiometa/stylelint-formatter-gitlab": "^1.0.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.1",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.3.2",
    "@typescript/lib-dom": "npm:@types/web@^0.0.338",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/coverage-istanbul": "^4.1.2",
    "@vue/eslint-config-typescript": "^14.7.0",
    "autoprefixer": "^10.4.27",
    "axe-html-reporter": "^2.2.11",
    "canonicalize": "^2.1.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-formatter-gitlab": "^7.0.1",
    "eslint-plugin-vue": "^10.8.0",
    "glob": "^13.0.6",
    "globals": "^17.3.0",
    "npm-audit-resolver": "^3.0.0-RC.0",
    "npm-check-updates": "^19.6.3",
    "nyc": "^18.0.0",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "resolve-tspaths": "^0.8.23",
    "rollup-plugin-license": "^3.7.1",
    "stylelint": "^16.26.1",
    "stylelint-config-standard": "^39.0.1",
    "stylelint-config-standard-vue": "^1.0.0",
    "stylelint-config-tailwindcss": "^1.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.2",
    "vite-plugin-istanbul": "^8.0.0",
    "vite-plugin-static-copy": "^4.0.0",
    "vitest": "^4.1.2",
    "vue-component-type-helpers": "^3.2.5",
    "vue-tsc": "^3.2.5"
  },
  "overrides": {
    "yaml": "2.8.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
