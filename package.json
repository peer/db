{
  "name": "@peerdb/peerdb",
  "version": "0.4.0-rc.0",
  "type": "module",
  "description": "A collaborative database.",
  "license": "Apache-2.0",
  "author": {
    "name": "PeerDB contributors",
    "url": "https://gitlab.com/peerdb/peerdb"
  },
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/peerdb/peerdb.git"
  },
  "module": "./lib/index.js",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js"
    },
    "./auth": {
      "types": "./lib/auth/index.d.ts",
      "import": "./lib/auth/index.js"
    },
    "./auth/*": {
      "types": "./lib/auth/*.d.ts",
      "import": "./lib/auth/*.js"
    },
    "./components/*": {
      "types": "./lib/components/*.d.ts",
      "import": "./lib/components/*.js"
    },
    "./core": {
      "types": "./lib/core/index.d.ts",
      "import": "./lib/core/index.js"
    },
    "./core/*": {
      "types": "./lib/core/*.d.ts",
      "import": "./lib/core/*.js"
    },
    "./document": {
      "types": "./lib/document/index.d.ts",
      "import": "./lib/document/index.js"
    },
    "./document/*": {
      "types": "./lib/document/*.d.ts",
      "import": "./lib/document/*.js"
    },
    "./partials/*": {
      "types": "./lib/partials/*.d.ts",
      "import": "./lib/partials/*.js"
    },
    "./registry/*": {
      "types": "./lib/registry/*.d.ts",
      "import": "./lib/registry/*.js"
    },
    "./views/*": {
      "types": "./lib/views/*.d.ts",
      "import": "./lib/views/*.js"
    },
    "./locales/*": {
      "import": "./lib/locales/*.js"
    },
    "./*.css": {
      "style": "./lib/*.css"
    },
    "./*": {
      "types": "./lib/*.d.ts",
      "import": "./lib/*.js"
    }
  },
  "files": [
    "lib"
  ],
  "scripts": {
    "serve": "vite serve",
    "build": "vite build",
    "build-lib": "vite build --config vite.config.lib.ts && vue-tsc -p tsconfig.lib.json && resolve-tspaths -p tsconfig.lib.json && node generate-vue-dts-proxies.js",
    "build-lib-watch": "vite build --config vite.config.lib.ts --watch",
    "lint": "eslint --fix src tests",
    "lint-ci": "eslint --fix --format gitlab src tests",
    "lint-style": "stylelint --fix src/**/*.{css,scss,vue,html}",
    "lint-style-ci": "stylelint --fix --custom-formatter=@studiometa/stylelint-formatter-gitlab src/**/*.{css,scss,vue,html}",
    "lint-vue": "vue-tsc --noEmit && vue-tsc -p tests/tsconfig.json --noEmit",
    "fmt": "prettier src tests *.ts *.js *.json .*.json --write",
    "test": "vitest",
    "coverage": "vitest --coverage",
    "test-ci": "vitest run --reporter junit --reporter default --outputFile tests.xml --coverage",
    "test-e2e": "playwright test --config=playwright.config.ts --update-snapshots=${UPDATE_SCREENSHOTS:-missing} && nyc report",
    "test-e2e-install": "playwright install --with-deps chromium",
    "generate-vue-i18n": "node generate-vue-i18n.js",
    "upgrade": "ncu -u --dep dev,optional,peer,prod,packageManager --peer",
    "check-audit": "check-audit",
    "resolve-audit": "resolve-audit",
    "prepare": "npm run build-lib"
  },
  "peerDependencies": {
    "@all1ndev/vue-local-scope": "^0.3.2",
    "@headlessui/vue": "github:tozd/headlessui#1cf40492bfe16f0ccaca4620bacfc4dd74bdf9a5",
    "@heroicons/vue": "^2.2.0",
    "@sidekickicons/vue": "^0.15.0",
    "@tozd/identifier": "^0.8.2",
    "@tozd/prosemirror": "^0.2.0",
    "esm-seedrandom": "^3.0.5-esm.2",
    "fflate": "^0.8.3",
    "hash-wasm": "^4.12.0",
    "heroicons": "^2.2.0",
    "lodash-es": "^4.18.1",
    "nouislider": "^15.8.1",
    "prosemirror-commands": "^1.7.1",
    "prosemirror-history": "^1.5.0",
    "prosemirror-keymap": "^1.2.3",
    "prosemirror-model": "^1.25.8",
    "prosemirror-schema-list": "^1.5.1",
    "prosemirror-state": "^1.4.4",
    "prosemirror-view": "^1.41.9",
    "structured-field-values": "^2.0.4",
    "tailwind-merge": "^3.6.0",
    "vue": "^3.5.38",
    "vue-i18n": "^11.1.12",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@babel/types": "^7.29.7",
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@headlessui/tailwindcss": "^0.2.2",
    "@intlify/devtools-types": "^11.4.5",
    "@intlify/unplugin-vue-i18n": "^11.2.3",
    "@playwright/test": "^1.60.0",
    "@studiometa/stylelint-formatter-gitlab": "^1.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.1",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.9.3",
    "@typescript/lib-dom": "npm:@types/web@^0.0.350",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-istanbul": "^4.1.8",
    "@vue/eslint-config-typescript": "^14.8.0",
    "autoprefixer": "^10.5.0",
    "axe-html-reporter": "^2.2.11",
    "canonicalize": "^3.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-formatter-gitlab": "^7.1.0",
    "eslint-plugin-vue": "^10.9.2",
    "glob": "^13.0.6",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "npm-audit-resolver": "^3.0.0-RC.0",
    "npm-check-updates": "^22.2.3",
    "nyc": "^18.0.0",
    "playwright-core": "^1.60.0",
    "prettier": "^3.8.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "resolve-tspaths": "^0.8.23",
    "rollup-plugin-license": "^3.7.1",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-vue": "^1.0.0",
    "stylelint-config-tailwindcss": "^1.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vite-plugin-istanbul": "^9.0.1",
    "vite-plugin-static-copy": "^4.1.1",
    "vitest": "^4.1.8",
    "vue-component-type-helpers": "^3.3.5",
    "vue-tsc": "^3.3.5"
  },
  "publishConfig": {
    "access": "public"
  },
  "overrides": {
    "uuid": "^14.0.0",
    "esbuild": "^0.28.1",
    "js-yaml": "^4.2.0"
  }
}
